# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요:
#   cp .env.example .env
# (.env 는 git에 올라가지 않습니다 — 실제 비밀값은 .env 에)

# docker-compose.yml 이 읽어가는 DB 계정 정보
POSTGRES_USER=diet
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dietlog

# Next.js(Prisma)가 쓰는 접속 주소 (위 USER/PASSWORD/DB 와 일치시킬 것)
DATABASE_URL="postgresql://diet:changeme@localhost:5432/dietlog?schema=public"

# 🤖 자연어 정리에 쓰는 LLM (OpenAI 호환 API) — Gemini/Ollama 등 교체 가능
# [무료] Google Gemini: https://aistudio.google.com/apikey 에서 키 발급
#   ⚠️ 무료 티어는 입력 데이터가 구글 모델 학습에 쓰일 수 있고 하루 요청 한도가 있음.
LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
LLM_API_KEY=""
LLM_MODEL="gemini-2.5-flash"

# [완전 무료·로컬] Ollama로 바꾸려면 위 3줄 대신:
# LLM_BASE_URL="http://localhost:11434/v1"
# LLM_API_KEY="ollama"
# LLM_MODEL="qwen2.5"
